# Server-only secret used by Expo Router API routes. Never prefix this with EXPO_PUBLIC_.
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token

# Deployed EAS Hosting origin used by native builds. Web uses same-origin /api routes.
EXPO_PUBLIC_API_BASE_URL=https://your-project.expo.app

# Adult nutrition analysis (server-only unless EXPO_PUBLIC_ is specified)
MEAL_AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MEAL_MODEL=gpt-5.6-terra
OPENAI_PLANT_MODEL=gpt-5.6-terra
# Plant analysis defaults to the same free local provider used by meal photos.
PLANT_AI_PROVIDER=ollama
LOCAL_PLANT_AI_ENABLED=true
OLLAMA_PLANT_MODEL=qwen3-vl:2b
# Only used when PLANT_AI_PROVIDER=openai.
PLANT_AI_ENABLED=false
USDA_FDC_API_KEY=your_data_gov_api_key
CLINICAL_AI_ENABLED=false
# Free local photo analysis for development. Keep the Ollama endpoint loopback-only.
LOCAL_MEAL_AI_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MEAL_MODEL=qwen3-vl:2b
EXPO_PUBLIC_NUTRITION_API_URL=https://your-project.expo.app
EXPO_PUBLIC_ADULT_NUTRITION_ENABLED=true

# Keep youth, infant, and PHI-bearing cloud paths off until release gates pass.
EXPO_PUBLIC_YOUTH_NUTRITION_ENABLED=false
EXPO_PUBLIC_INFANT_CLINICAL_ENABLED=false
EXPO_PUBLIC_CLINICAL_CLOUD_ENABLED=false
CLINICAL_CLOUD_ENABLED=false

# High-compliance Supabase project. Publishable values are client-safe; never
# expose the service role key to the app.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
