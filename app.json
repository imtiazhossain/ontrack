{
  "expo": {
    "name": "onTrack",
    "slug": "onTrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ontrack",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.imtihoss.ontracknow",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "onTrack uses the camera to capture meal and progress photos for your daily tracking.",
        "NSPhotoLibraryUsageDescription": "onTrack accesses your photo library so you can attach meal and progress photos to activities.",
        "NSMicrophoneUsageDescription": "The microphone may be used when recording videos for activity notes.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "onTrack accesses your photos so you can attach meal and progress photos to activities.",
          "cameraPermission": "onTrack uses the camera to capture meal and progress photos."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bd232bf6-7397-4463-b25a-9b67d78e5695"
      }
    },
    "owner": "imtihoss"
  }
}
